{
  "manifest_version": 3,
  "name": "TrustLens – Fake Review Detector",
  "version": "2.0.0",
  "content_scripts": [
    {
      "matches": [
        "*://*.amazon.com/*",
        "*://*.amazon.in/*",
        "*://*.flipkart.com/*"
      ],
      "js": [
        "src/adapters/platformAdapter.js",
        "src/adapters/amazonAdapter.js",
        "src/adapters/flipkartAdapter.js",
        "src/adapters/genericAdapter.js",
        "src/extraction/ratingExtractor.js",
        "src/preprocessing/preprocessor.js",
        "src/features/featureEngineer.js",
        "src/analysis/sentimentRatingEngine.js",
        "src/persona/userProfileBuilder.js",
        "src/persona/personaEngine.js",
        "src/scoring/scoringEngine.js",
        "src/trust/trustEngine.js",
        "src/ui/overlay.js",
        "content.js" 
      ],
      "css": ["src/ui/overlay.css"],
      "run_at": "document_end"
    }
  ],
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "*://*.amazon.in/*",
    "*://*.amazon.com/*",
    "*://*.flipkart.com/*"
  ]
}
